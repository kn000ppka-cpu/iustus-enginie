{
  "name": "iustus-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Iustus Engine — профессиональный инструмент расчёта вида и срока уголовного наказания по УК РФ",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:telegram": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:https": "vite preview --port 5173 --host",
    "lint": "eslint . --ext ts,tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:start": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:make:win": "npm run build && electron-builder --win nsis --x64",
    "electron:make:win:portable": "npm run build && electron-builder --win portable --x64",
    "electron:make:win:dir": "npm run build && electron-builder --win dir --x64",
    "electron:make:mac": "npm run build && electron-builder --mac dmg --x64 --arm64",
    "electron:make:linux": "npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "immer": "^10.1.1",
    "pdfmake": "^0.2.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/pdfmake": "^0.2.9",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.11",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "ru.iustus.engine",
    "productName": "Iustus Engine",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Iustus-Engine-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Iustus Engine"
    },
    "portable": {
      "artifactName": "Iustus-Engine-${version}-Portable-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    }
  }
}
